const CATEGORIES = ["All", "Pizza", "Burgers", "Sushi", "Desserts", "Asian"];

let activeCategory = "All";
let searchQuery = "";
let sortBy = "default";

// DOM Safe Fetching Routine
const getEl = (id) => document.getElementById(id);

// Application Initialization Lifecycle
window.addEventListener("DOMContentLoaded", () => {
    // Structural Guard: Ensure elements are configured layout-wise
    const grid = getEl("restaurant-grid");
    const catContainer = getEl("category-container");

    if (grid) {
        grid.style.display = "grid";
        grid.style.gridTemplateColumns = "repeat(auto-fill, minmax(285px, 1fr))";
        grid.style.gap = "20px";
        grid.style.padding = "10px 0";
    }
    
    if (catContainer) {
        catContainer.style.display = "flex";
        catContainer.style.gap = "10px";
        catContainer.style.overflowX = "auto";
        catContainer.style.padding = "10px 0";
    }

    renderCategories();
    filterAndRenderRestaurants();
    
    // Attach event listener if sort element exists
    const sortSelect = getEl("sort-select");
    if (sortSelect) {
        sortSelect.addEventListener("change", (e) => {
            sortBy = e.target.value;
            filterAndRenderRestaurants();
        });
    }
});

// Category Pill Generator
function renderCategories() {
    const container = getEl("category-container");
    if (!container) return;
    
    container.innerHTML = "";
    CATEGORIES.forEach(cat => {
        const pill = document.createElement("button");
        pill.className = `category-pill ${cat === activeCategory ? 'active' : ''}`;
        pill.style.padding = "8px 16px";
        pill.style.borderRadius = "20px";
        pill.style.border = "1px solid #ddd";
        pill.style.background = cat === activeCategory ? "#ff4757" : "#fff";
        pill.style.color = cat === activeCategory ? "#fff" : "#333";
        pill.style.cursor = "pointer";
        pill.innerText = cat;
        
        pill.addEventListener("click", () => {
            activeCategory = cat;
            renderCategories();
            filterAndRenderRestaurants();
        });
        container.appendChild(pill);
    });
}

// Processing pipeline and Card Injector Engine
function filterAndRenderRestaurants() {
    const grid = getEl("restaurant-grid");
    if (!grid) return;

    // Apply Filter Pipeline Routines
    let result = RESTAURANTS_DATA.filter(res => {
        const matchesCat = activeCategory === "All" || res.category === activeCategory;
        const matchesSearch = res.name.toLowerCase().includes(searchQuery);
        return matchesCat && matchesSearch;
    });

    // Apply Sorting Pipelines
    if (sortBy === "rating") {
        result.sort((a, b) => b.rating - a.rating);
    } else if (sortBy === "deliveryTime") {
        result.sort((a, b) => a.deliveryMin - b.deliveryMin);
    }

    // Dynamic Node Insertion Lifecycle
    grid.innerHTML = "";
    if (result.length === 0) {
        grid.innerHTML = `<p style="grid-column: 1/-1;">No matching restaurants found.</p>`;
        return;
    }

    result.forEach(res => {
        const card = document.createElement("div");
        card.className = "restaurant-card";
        card.style.border = "1px solid #eee";
        card.style.borderRadius = "12px";
        card.style.overflow = "hidden";
        card.style.background = "#fff";
        card.style.boxShadow = "0 4px 6px rgba(0,0,0,0.05)";
        
        card.innerHTML = `
            <div style="height: 160px; position: relative;">
                <img src="${res.image}" alt="${res.name}" style="width: 100%; height: 100%; object-fit: cover;">
                <span style="position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.7); color: #fff; padding: 4px 8px; border-radius: 4px; font-size: 12px;">
                    ${res.deliveryTime}
                </span>
            </div>
            <div style="padding: 15px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <h3 style="margin: 0; font-size: 18px;">${res.name}</h3>
                    <span style="background: #eef9f2; color: #1e7e34; padding: 2px 6px; border-radius: 4px; font-size: 13px; font-weight: bold;">
                        ★ ${res.rating}
                    </span>
                </div>
                <div style="display: flex; justify-content: space-between; color: #666; font-size: 14px;">
                    <span>${res.category}</span>
                    <span style="font-weight: bold; color: #333;">${res.priceIndicator}</span>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
}